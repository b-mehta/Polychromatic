import Mathlib.Analysis.Complex.Exponential
import Mathlib.Analysis.RCLike.Basic
import Mathlib.MeasureTheory.Measure.Real
import Polychromatic.ForMathlib.Misc

/-!
# The Lov├Аsz Local Lemma

This file contains a formalization of the Lov├Аsz Local Lemma, a powerful tool in
probabilistic combinatorics for proving the existence of objects avoiding many "bad" events.

## Main definitions

* `IndepFrom s t P`: Event `s` is independent of the ¤Ѓ-algebra generated by events in `t`.
* `lopsidedCondition P A N`: The lopsided condition for the local lemma, stating that
  each event `A i` is "approximately independent" of events outside its neighbourhood `N i`.
* `standardCondition P A N`: The standard independence condition, stronger than lopsided.
* `IndividualBound P A x i S`: An upper bound on `P(A i РѕЕ РІѓ_{j Рѕѕ S} AР▒╝рХю)`.

## Main results

* `localLemma`: The general Lov├Аsz Local Lemma with individual bounds.
* `symmetricLocalLemma`: The symmetric version where all events have the same probability
  bound `p` and neighbourhood size bound `d`. If `e ┬и p ┬и (d + 1) РЅц 1`, then
  `P(РІѓрхб AрхбрХю) РЅЦ РѕЈрхб (1 - xрхб) > 0`.
* `standardCondition_of`: A way to construct the standard condition from independence
  structure of random variables.

## Implementation notes

The lemma is proven using induction on subsets, following the standard probabilistic proof.
The key insight is that conditional probabilities can be bounded using the independence structure.
There are many variants of the Local Lemma, and we aim to support a few of them.

## References

* Lov├Аsz, L├Аszl├│ (1975). "Problems and results on 3-chromatic hypergraphs and some related
  questions". Infinite and finite sets.
* Erd┼Љs, Paul; Lov├Аsz, L├Аszl├│ (1975). "Problems and results on 3-chromatic hypergraphs and
  some related questions".
-/

open MeasureTheory ProbabilityTheory Measure

variable {╬╣ ╬Е : Type*} {h╬Е : MeasurableSpace ╬Е} {P : Measure ╬Е}

section

open MeasurableSpace Measure

variable {s : Set ╬Е} {t t' : Set (Set ╬Е)}

/-- Event `s` is independent of the ¤Ѓ-algebra generated by events in `t`. -/
def IndepFrom (s : Set ╬Е) (t : Set (Set ╬Е)) (P : Measure ╬Е) : Prop :=
  Indep (generateFrom {s}) (generateFrom t) P

lemma indepFrom_iff_indepSets {P : Measure ╬Е} [IsZeroOrProbabilityMeasure P]
    {s : Set ╬Е} {t : Set (Set ╬Е)} (hs : MeasurableSet s) (ht : Рѕђ i Рѕѕ t, MeasurableSet i) :
    IndepFrom s t P Рєћ IndepSets {s} (generatePiSystem t) P := by
  rw [IndepFrom, Рєљ generateFrom_generatePiSystem_eq (g := t)]
  constructor
  ┬и intro h
    exact h.indepSets
  ┬и intro h
    apply h.indep' _ _ (.singleton s) (isPiSystem_generatePiSystem _)
    ┬и simpa
    ┬и exact generatePiSystem_measurableSet ht

lemma IndepFrom.prob_inter_iInter [Countable ╬╣] (h : IndepFrom s t P) {A : ╬╣ Рєњ Set ╬Е}
    (ht : Рѕђ i, A i Рѕѕ t Рѕе (A i)рХю Рѕѕ t) : P (s РѕЕ РІѓ i, A i) = P s * P (РІѓ i, A i) := by
  rw [IndepFrom, Indep_iff] at h
  rw [h]
  ┬и exact .basic _ (by simp)
  apply MeasurableSet.iInter
  intro i
  obtain h | h := ht i
  ┬и exact .basic _ h
  ┬и exact .of_compl (.basic _ h)

lemma IndepFrom.prob_inter_biInter (h : IndepFrom s t P) {C : Set ╬╣} {A : ╬╣ Рєњ Set ╬Е}
    (hC : C.Countable) (ht : Рѕђ i Рѕѕ C, A i Рѕѕ t Рѕе (A i)рХю Рѕѕ t) :
    P (s РѕЕ РІѓ i Рѕѕ C, A i) = P s * P (РІѓ i Рѕѕ C, A i) := by
  have : Countable C := by simpa
  simpa using h.prob_inter_iInter (╬╣ := C) (A := A Рѕў Subtype.val) (by simpa)

lemma IndepFrom.prob_inter_sInter (h : IndepFrom s t P) (ht' : t'.Countable)
    (ht : Рѕђ i Рѕѕ t', i Рѕѕ t Рѕе iрХю Рѕѕ t) : P (s РѕЕ РІѓРѓђ t') = P s * P (РІѓРѓђ t') := by
  rw [Set.sInter_eq_biInter]
  exact h.prob_inter_biInter ht' ht

variable [IsProbabilityMeasure P]

lemma IndepFrom.cond_iInter [Countable ╬╣] (h : IndepFrom s t P)
    {A : ╬╣ Рєњ Set ╬Е} (hs : MeasurableSet s) (ht : Рѕђ i, A i Рѕѕ t Рѕе (A i)рХю Рѕѕ t)
    (htРѓђ : P (РІѓ i, A i) РЅа 0) :
    P[s | РІѓ i, A i] = P s := by
  rw [cond_apply' hs, Set.inter_comm, h.prob_inter_iInter ht, mul_left_comm,
    ENNReal.inv_mul_cancel htРѓђ (by simp), mul_one]

lemma IndepFrom.cond_biInter (h : IndepFrom s t P) {C : Set ╬╣}
    {A : ╬╣ Рєњ Set ╬Е} (hC : C.Countable) (hs : MeasurableSet s) (ht : Рѕђ i Рѕѕ C, A i Рѕѕ t Рѕе (A i)рХю Рѕѕ t)
    (htРѓђ : P (РІѓ i Рѕѕ C, A i) РЅа 0) :
    P[s | РІѓ i Рѕѕ C, A i] = P s := by
  have : Countable C := by simpa
  simpa using h.cond_iInter (╬╣ := C) (A := A Рѕў Subtype.val) hs (by simpa) (by simpa)

lemma IndepFrom.cond_sInter (h : IndepFrom s t P) (hs : MeasurableSet s)
    (ht' : t'.Countable) (ht : Рѕђ i Рѕѕ t', i Рѕѕ t Рѕе iрХю Рѕѕ t) (htРѓђ : P (РІѓРѓђ t') РЅа 0) :
    P[s | РІѓРѓђ t'] = P s := by
  rw [Set.sInter_eq_biInter] at htРѓђ Ріб
  exact h.cond_biInter ht' hs ht (by simpa using htРѓђ)

end


variable {A : ╬╣ Рєњ Set ╬Е} {N : ╬╣ Рєњ Finset ╬╣} {x : ╬╣ Рєњ РёЮ} {i j : ╬╣} {S T : Finset ╬╣}

/-- The lopsided condition for the local lemma, stating that each event `A i` is
"approximately independent" of events outside its neighbourhood `N i`. -/
def lopsidedCondition (P : Measure ╬Е) (A : ╬╣ Рєњ Set ╬Е) (N : ╬╣ Рєњ Finset ╬╣) : Prop :=
  Рѕђ i : ╬╣, Рѕђ S : Finset ╬╣, i РѕЅ S Рєњ Disjoint (N i) S Рєњ
    P (A i РѕЕ РІѓ j Рѕѕ S, (A j)рХю) РЅц P (A i) * P (РІѓ j Рѕѕ S, (A j)рХю)

lemma lopsidedCondition.real [IsProbabilityMeasure P]
    (h : lopsidedCondition P A N) (hiS : i РѕЅ S) (hS : Disjoint (N i) S) :
    P.real (A i РѕЕ РІѓ j Рѕѕ S, (A j)рХю) РЅц P.real (A i) * P.real (РІѓ j Рѕѕ S, (A j)рХю) := by
  rw [real_def, real_def, real_def, Рєљ ENNReal.toReal_mul,
    ENNReal.toReal_le_toReal (by finiteness) (by finiteness)]
  exact h _ _ hiS hS

/-- The standard independence condition for the local lemma, stronger than lopsided. -/
def standardCondition (P : Measure ╬Е) (A : ╬╣ Рєњ Set ╬Е) (N : ╬╣ Рєњ Finset ╬╣) : Prop :=
  Рѕђ i : ╬╣, IndepFrom (A i) (A '' (insert i (N i))рХю) P

lemma lopsidedCondition_of_standardCondition [IsProbabilityMeasure P]
    (h : standardCondition P A N) :
    lopsidedCondition P A N := by
  intro i S hiS hS
  specialize h i
  simp only [Рєљ Finset.mem_coe (s := S)]
  rw [h.prob_inter_biInter (C := (S : Set ╬╣)) (A := fun i Рєд (A i)рХю) S.countable_toSet _]
  intro j hj
  simp only [Finset.mem_coe] at hj
  right
  simp only [compl_compl]
  rw [Finset.disjoint_right] at hS
  apply Set.mem_image_of_mem
  simp only [Set.mem_compl_iff, Set.mem_insert_iff, Finset.mem_coe] -- TODO: try removing the simp
  grind

/-- An upper bound on `P(A i РѕЕ РІѓ_{j Рѕѕ S} AР▒╝рХю)`. -/
def IndividualBound (P : Measure ╬Е) (A : ╬╣ Рєњ Set ╬Е) (x : ╬╣ Рєњ РёЮ) (i : ╬╣) (S : Finset ╬╣) : Prop :=
  P.real (A i РѕЕ РІѓ j Рѕѕ S, (A j)рХю) РЅц x i * P.real (РІѓ j Рѕѕ S, (A j)рХю)

lemma IndividualBound.compl [IsProbabilityMeasure P] (hA : MeasurableSet (A i))
    (h : IndividualBound P A x i S) :
    (1 - x i) * P.real (РІѓ j Рѕѕ S, (A j)рХю) РЅц P.real ((A i)рХю РѕЕ РІѓ j Рѕѕ S, (A j)рХю) := by
  rw [IndividualBound] at h
  grw [one_sub_mul, Рєљ h, Рєљ Set.diff_eq_compl_inter, Set.inter_comm, sub_le_iff_le_add,
    Рєљ measureReal_diff_add_inter hA]

open Finset

lemma iteration [DecidableEq ╬╣] [IsProbabilityMeasure P] (hA : Рѕђ i, MeasurableSet (A i))
    {t t' : Finset ╬╣} (ht : Disjoint t t')
    (hxРѓЂ : Рѕђ i, x i РЅц 1)
    (S : Finset ╬╣)
    (htS : t Ріє S)
    (ht'S : t' Ріє S)
    (h : Рѕђ T Ріѓ S, Рѕђ {i}, i РѕЅ T Рєњ IndividualBound P A x i T) :
    (РѕЈ j Рѕѕ t, (1 - x j)) * P.real (РІѓ j Рѕѕ t', (A j)рХю) РЅц P.real (РІѓ j Рѕѕ t Рѕф t', (A j)рХю) := by
  induction t using cons_induction_on with
  | empty => simp
  | cons a t hat ih =>
    replace РЪеhat', httРЪЕ : a РѕЅ t' РѕД Disjoint t t' := by simpa using ht
    simp only [cons_eq_insert] at htS
    suffices ((1 - x a) * РѕЈ j Рѕѕ t, (1 - x j)) * P.real (РІѓ j Рѕѕ t', (A j)рХю) РЅц
        P.real ((A a)рХю РѕЕ (РІѓ x Рѕѕ t Рѕф t', (A x)рХю)) by simpa [- mem_union, hat] using this
    calc
      _ = (1 - x a) * ((РѕЈ j Рѕѕ t, (1 - x j)) * P.real (РІѓ j Рѕѕ t', (A j)рХю)) := by ring
      _ РЅц (1 - x a) * P.real (РІѓ j Рѕѕ t Рѕф t', (A j)рХю) := by
        gcongr
        ┬и simp [hxРѓЂ]
        ┬и apply ih htt ((subset_insert _ _).trans htS)
      _ РЅц _ := by
        have ha : a РѕЅ t Рѕф t' := by simp [hat, hat']
        have : insert a (t Рѕф t') Ріє S := by
          simpa [insert_subset_iff, union_subset_iff, ht'S] using htS
        exact (h _ (Finset.ssubset_of_ssubset_of_subset (ssubset_insert ha) this) ha).compl (hA _)

lemma iteration_all [IsProbabilityMeasure P] (hA : Рѕђ i, MeasurableSet (A i))
    {t : Finset ╬╣}
    (hxРѓЂ : Рѕђ i, x i РЅц 1)
    (h : Рѕђ i : ╬╣, Рѕђ S : Finset ╬╣, i РѕЅ S Рєњ IndividualBound P A x i S) :
    РѕЈ j Рѕѕ t, (1 - x j) РЅц P.real (РІѓ j Рѕѕ t, (A j)рХю) := by
  have : Рѕђ T Ріѓ t, Рѕђ {i}, i РѕЅ T Рєњ IndividualBound P A x i T := by
    intro T hTt i hiT
    exact h i T hiT
  classical
  simpa using iteration (P := P) hA (t' := РѕЁ) (by simp) hxРѓЂ t (by simp) (by simp) this

lemma prod_le_prod_of_subset_of_le_one {╬▒ : Type*} [CommMonoidWithZero ╬▒] [PartialOrder ╬▒]
    [PosMulMono ╬▒] [ZeroLEOneClass ╬▒]
    {x : ╬╣ Рєњ ╬▒} {s t : Finset ╬╣} (hst : s Ріє t)
    (hxРѓђ : Рѕђ i, 0 РЅц x i) (hxРѓЂ : Рѕђ i, x i РЅц 1) :
    РѕЈ j Рѕѕ t, x j РЅц РѕЈ j Рѕѕ s, x j := by classical calc
  РѕЈ j Рѕѕ t, x j = (РѕЈ j Рѕѕ t РѕЕ s, x j) * РѕЈ j Рѕѕ t \ s, x j := by
    rw [prod_inter_mul_prod_diff]
  _ РЅц (РѕЈ j Рѕѕ t РѕЕ s, x j) * 1 := by
    gcongr
    ┬и apply prod_nonneg
      simp [hxРѓђ]
    ┬и apply prod_le_one (by simp [hxРѓђ]) (by simp [hxРѓЂ])
  _ = РѕЈ j Рѕѕ s, x j := by simp [inter_eq_right.2 hst]

lemma individualBound [DecidableEq ╬╣] [IsProbabilityMeasure P] (hA : Рѕђ i, MeasurableSet (A i))
    (hN : lopsidedCondition P A N)
    (hxРѓђ : Рѕђ i, 0 РЅц x i) (hxРѓЂ : Рѕђ i, x i РЅц 1)
    (hAx : Рѕђ i, P.real (A i) РЅц x i * РѕЈ j Рѕѕ N i, (1 - x j))
    (hiS : i РѕЅ S) :
    IndividualBound P A x i S := by
  induction S using strongInduction generalizing i with
  | H S ih =>
    let SРѓЂ : Finset ╬╣ := S РѕЕ N i
    let SРѓѓ : Finset ╬╣ := S \ SРѓЂ
    have hS : SРѓЂ Рѕф SРѓѓ = S := by simp [SРѓЂ, SРѓѓ, union_comm (S РѕЕ N i), sdiff_union_inter]
    rw [IndividualBound]
    calc
      P.real (A i РѕЕ РІѓ j Рѕѕ S, (A j)рХю) РЅц P.real (A i РѕЕ РІѓ j Рѕѕ SРѓѓ, (A j)рХю) := by
        rw [Рєљ hS, Finset.set_biInter_inter]
        refine measureReal_mono ?_
        gcongr
        exact Set.inter_subset_right
      _ РЅц P.real (A i) * P.real (РІѓ j Рѕѕ SРѓѓ, (A j)рХю) :=
        hN.real (by simp [SРѓѓ, hiS]) (by simp [SРѓѓ, SРѓЂ, disjoint_sdiff])
      _ РЅц x i * (РѕЈ j Рѕѕ N i, (1 - x j)) * P.real (РІѓ j Рѕѕ SРѓѓ, (A j)рХю) := by gcongr; exact hAx i
      _ = x i * ((РѕЈ j Рѕѕ N i, (1 - x j)) * P.real (РІѓ j Рѕѕ SРѓѓ, (A j)рХю)) := by ring
      _ РЅц x i * ((РѕЈ j Рѕѕ SРѓЂ, (1 - x j)) * P.real (РІѓ j Рѕѕ SРѓѓ, (A j)рХю)) := by
        gcongr
        ┬и exact hxРѓђ i
        apply prod_le_prod_of_subset_of_le_one (by simp [SРѓЂ]) (by simp [hxРѓЂ]) (by simp [hxРѓђ])
      _ РЅц x i * P.real (РІѓ j Рѕѕ S, (A j)рХю) := by
        gcongr
        ┬и exact hxРѓђ i
        rw [Рєљ hS]
        exact iteration hA disjoint_sdiff hxРѓЂ _ (by simp [SРѓЂ]) (by simp [SРѓѓ]) ih

/-- The general Lov├Аsz Local Lemma with individual bounds: if `P(A i) РЅц x i * РѕЈ_{j Рѕѕ N i} (1 - x j)`
for all `i`, then `P(РІѓрхб AрхбрХю) РЅЦ РѕЈрхб (1 - xрхб) > 0`. -/
theorem localLemma [Fintype ╬╣] [IsProbabilityMeasure P] (hA : Рѕђ i, MeasurableSet (A i))
    (hxРѓђ : Рѕђ i, 0 РЅц x i) (hxРѓЂ : Рѕђ i, x i РЅц 1)
    (h : lopsidedCondition P A N)
    (hAx : Рѕђ i, P.real (A i) РЅц x i * РѕЈ j Рѕѕ N i, (1 - x j)) :
    РѕЈ i, (1 - x i) РЅц P.real (РІѓ i, (A i)рХю) := by
  have : Рѕђ i, Рѕђ S, i РѕЅ S Рєњ IndividualBound P A x i S := by
    intro i S hiS
    classical
    exact individualBound hA h hxРѓђ hxРѓЂ hAx hiS
  simpa using iteration_all hA hxРѓЂ this (t := univ)

lemma add_one_div_pow_le_exp {t : РёЮ} {n : РёЋ} (hn : n РЅа 0) (ht : 0 РЅц 1 + t / n) :
    (1 + t / n) ^ n РЅц Real.exp t := by
  grw [add_comm, Real.add_one_le_exp, Рєљ Real.exp_nat_mul, mul_div_cancelРѓђ _ (by simpa)]
  rwa [add_comm]

lemma add_one_inv_pow_le_exp {n : РёЋ} : (1 + (n : РёЮ)РЂ╗┬╣) ^ n РЅц Real.exp 1 := by
  obtain rfl | hnРѓђ := eq_or_ne n 0
  ┬и simp
  simpa using add_one_div_pow_le_exp (t := 1) hnРѓђ (by positivity)

/-- The symmetric Lov├Аsz Local Lemma: if all events have probability at most `p` and
neighbourhood size at most `d`, and `e ┬и p ┬и (d + 1) РЅц 1`, then `P(РІѓрхб AрхбрХю) > 0`. -/
theorem symmetricLocalLemma [Fintype ╬╣] [IsProbabilityMeasure P] (hA : Рѕђ i, MeasurableSet (A i))
    {d : РёЋ} (hd : d РЅа 0) {p : РёЮ} (h : lopsidedCondition P A N) (hAp : Рѕђ i, P.real (A i) РЅц p)
    (hN : Рѕђ i, #(N i) РЅц d)
    (hpd : Real.exp 1 * p * (d + 1) РЅц 1) :
    0 < P.real (РІѓ i, (A i)рХю) := by
  let x (i : ╬╣) : РёЮ := (d + 1)РЂ╗┬╣
  have hxРѓђ (i : ╬╣) : 0 РЅц x i := by positivity
  have hxРѓЂ (i : ╬╣) : x i < 1 := inv_lt_one_of_one_ltРѓђ (by simp [hd, pos_iff_ne_zero])
  suffices hx : Рѕђ i, P.real (A i) РЅц x i * РѕЈ j Рѕѕ N i, (1 - x j) from
    (localLemma hA hxРѓђ (fun i Рєд (hxРѓЂ i).le) h hx).trans_lt' (prod_pos (by simp [hxРѓЂ]))
  intro i
  calc
    P.real (A i) РЅц p := hAp _
    _ РЅц (d + 1 : РёЮ)РЂ╗┬╣ * (Real.exp 1)РЂ╗┬╣ := by
      rw [Рєљ mul_inv, Рєљ one_div, le_div_iffРѓђ]
      ┬и linear_combination hpd
      ┬и positivity
    _ РЅц (d + 1 : РёЮ)РЂ╗┬╣ * (1 + (РєЉd)РЂ╗┬╣)РЂ╗┬╣ ^ d := by
      grw [inv_pow, add_one_inv_pow_le_exp]
    _ = (d + 1 : РёЮ)РЂ╗┬╣ * (1 - (d + 1 : РёЮ)РЂ╗┬╣) ^ d := by
      congr! 2
      simp [field]
    _ РЅц (d + 1 : РёЮ)РЂ╗┬╣ * РѕЈ j Рѕѕ N i, (1 - (d + 1 : РёЮ)РЂ╗┬╣) := by
      simp only [prod_const]
      gcongr _ * ?_
      apply pow_le_pow_of_le_one _ _ (by grind)
      ┬и simpa using (hxРѓЂ i).le
      ┬и simpa [x] using hxРѓђ i
    _ = x i * РѕЈ j Рѕѕ N i, (1 - x j) := rfl

lemma eq_sInter_of_mem_generatePiSystem {╬Е : Type*} {t : Set (Set ╬Е)} {A : Set ╬Е}
    (hA : A Рѕѕ generatePiSystem t) :
    РѕЃ S : Set (Set ╬Е), S Ріє t РѕД A = РІѓРѓђ S := by
  induction hA with
  | @base s hs =>
    refine РЪе{s}, by simpa, by simpРЪЕ
  | @inter sРѓЂ sРѓѓ _ _ h hsРѓЂ hsРѓѓ =>
    obtain РЪеSРѓЂ, hSРѓЂ, rflРЪЕ := hsРѓЂ
    obtain РЪеSРѓѓ, hSРѓѓ, rflРЪЕ := hsРѓѓ
    refine РЪеSРѓЂ Рѕф SРѓѓ, Set.union_subset hSРѓЂ hSРѓѓ, by simp [Set.sInter_union]РЪЕ

lemma dependsOn_mem_iff_exists_preimage {╬▒ ╬▓ : Type*} {t : Set ╬▒} {A : Set (╬▒ Рєњ ╬▓)} :
    DependsOn (┬и Рѕѕ A) t Рєћ РѕЃ B : Set (t Рєњ ╬▓), A = t.restrict РЂ╗┬╣' B :=
  dependsOn_iff_exists_comp

/-- A way to construct the standard condition from independence structure of random variables. -/
lemma standardCondition_of {╬▒ ╬▓ : Type*} [Fintype ╬╣] [MeasurableSpace ╬▓] [IsProbabilityMeasure P]
    (I : ╬▒ Рєњ ╬Е Рєњ ╬▓) {A : ╬╣ Рєњ Set ╬Е} {N : ╬╣ Рєњ Finset ╬╣} (D : ╬╣ Рєњ Finset ╬▒)
    (hND : Рѕђ i j, i РЅа j Рєњ i РѕЅ N j Рєњ Disjoint (D i) (D j))
    (hI : Рѕђ a : ╬▒, Measurable (I a))
    (hI' : iIndepFun I P)
